# SMF Social v2 - Test Environment Configuration
# Copy to .env and fill in your OAuth credentials

# =============================================================================
# SECURITY (REQUIRED)
# =============================================================================
JWT_SECRET=test-jwt-secret-change-in-production
ENCRYPTION_KEY=test-encryption-key-min-32-chars!!

# =============================================================================
# DATABASE
# =============================================================================
DATABASE_URL=sqlite:///data/smf_social_test.db
DATA_DIR=./data

# =============================================================================
# API SETTINGS
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_URL=http://localhost:3000
DEBUG=true

# =============================================================================
# PINTEREST OAUTH
# =============================================================================
# Get from: https://developers.pinterest.com/apps/
PINTEREST_CLIENT_ID=your_pinterest_client_id
PINTEREST_CLIENT_SECRET=your_pinterest_client_secret
PINTEREST_REDIRECT_URI=http://localhost:8000/api/auth/pinterest/callback

# =============================================================================
# LINKEDIN OAUTH
# =============================================================================
# Get from: https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
LINKEDIN_REDIRECT_URI=http://localhost:8000/api/auth/linkedin/callback

# =============================================================================
# X (TWITTER) OAUTH
# =============================================================================
# Get from: https://developer.twitter.com/en/portal/projects-and-apps
X_API_KEY=your_x_api_key
X_API_SECRET=your_x_api_secret
X_REDIRECT_URI=http://localhost:8000/api/auth/x/callback

# =============================================================================
# TESTING
# =============================================================================
# Set to true to skip OAuth and use mock data
MOCK_OAUTH=false
